# MemFuse Server Configuration
# Copy this file to .env and adjust values for your setup.

# -- Required ------------------------------------------------------
# MemFuse home directory — config, data, and logs all live here.
# Defaults to ~/.memfuse if unset.
# MEMFUSE_HOME=~/.memfuse

# Workspace root directory — where MemFuse stores its internal data
# (SQLite databases, session files, projected resources, etc.)
# Defaults to $MEMFUSE_HOME/data.
MEMFUSE_WORKSPACE_ROOT=~/.memfuse/data

# Startup source mode. "managed" starts an empty MemFuse data plane; add
# searchable content later through /resources or `memfuse add-resource`.
MEMFUSE_SOURCE_KIND=managed
# Required only when MEMFUSE_SOURCE_KIND is "localfs" or "git".
# MEMFUSE_SOURCE_PATH=/path/to/source-data

# -- Server ---------------------------------------------------------
# Bind address for repo-local development
MEMFUSE_BIND_ADDR=127.0.0.1:18720

# Identity defaults
MEMFUSE_ACCOUNT_ID=default
MEMFUSE_USER_ID=default
MEMFUSE_AGENT_ID=default

# -- Canvas DB mode (default: shared) -------------------------------
# When true, canvas tables (nodes, edges, snapshots) live in a separate
# canvas.sqlite alongside metadata.sqlite. When false (default), they
# share the same metadata.sqlite. SaaS deployments may enable this for
# future PostgreSQL swap via CanvasStore trait.
# MEMFUSE_CANVAS_SEPARATE_DB=false

# -- LLM / OpenAI (optional — deterministic fallback used if absent) --
# OpenAI-compatible API key (checked first: MEMFUSE_OPENAI_API_KEY, then OPENAI_API_KEY)
MEMFUSE_OPENAI_API_KEY=
# OpenAI-compatible API base (default: https://api.openai.com/v1)
MEMFUSE_OPENAI_API_BASE=https://api.openai.com/v1
# Summary and chat models (default: gpt-4.1-mini)
MEMFUSE_SUMMARY_MODEL=gpt-4.1-mini
MEMFUSE_CHAT_MODEL=gpt-4.1-mini

# -- Jina (optional — enables semantic embeddings and reranking) ----
# When MEMFUSE_JINA_API_KEY is set, Jina is used for embeddings automatically.
# No need to set MEMFUSE_EMBEDDING_MODEL — Jina has its own config below.
MEMFUSE_JINA_API_KEY=
# Jina embedding model (default: jina-embeddings-v4, 2048 dimensions hardcoded)
# Only set these if you want to override the defaults:
# MEMFUSE_JINA_EMBEDDING_MODEL=jina-embeddings-v4
# MEMFUSE_JINA_EMBEDDING_DIMENSIONS=2048   # must be one of: 128, 256, 512, 1024, 2048

# -- Resilience ----------------------------------------------------
MEMFUSE_MAX_RETRIES=3
MEMFUSE_RETRY_BASE_DELAY_MS=500
MEMFUSE_RETRY_MAX_DELAY_MS=8000
MEMFUSE_CB_FAILURE_THRESHOLD=5
MEMFUSE_CB_RESET_TIMEOUT_MS=300000

# -- SDK ------------------------------------------------------------
# Server URL for hooks and MCP client
MEMFUSE_SERVER_URL=http://127.0.0.1:18720

# -- Security -------------------------------------------------------
# Auth mode: "dev" (no auth, default) or "api_key" (requires MEMFUSE_API_KEY)
MEMFUSE_AUTH_MODE=dev
# API key for api_key auth mode (clients must send Authorization: Bearer <key>)
MEMFUSE_API_KEY=
# Comma-separated list of allowed domains for URL resource imports (SSRF protection)
# Leave empty to allow all domains. Example: github.com,gitlab.com
MEMFUSE_ALLOWED_URL_DOMAINS=
# Enable/disable SSRF validation for URL resources (default: true)
MEMFUSE_URL_SSRF_CHECK=true

# -- CORS (default: enabled, allow all origins in dev mode) --------
# Enable/disable CORS headers (default: true)
MEMFUSE_CORS_ENABLED=true
# Comma-separated allowed origins (default: * in dev mode; set specific origins for production)
# Example: http://localhost:3000,https://dashboard.example.com
MEMFUSE_CORS_ORIGINS=

# -- Rate Limiting & Body Limits (default: enabled) -----------------
# Enable/disable rate limiting (default: true)
MEMFUSE_RATE_LIMIT_ENABLED=true
# Rate limits per minute per IP by category
MEMFUSE_RATE_LIMIT_EXPENSIVE=10
MEMFUSE_RATE_LIMIT_STANDARD=60
MEMFUSE_RATE_LIMIT_WRITE=30
# Request body size limits (MB)
MEMFUSE_MAX_BODY_SIZE_MB=10
MEMFUSE_MAX_IMPORT_SIZE_MB=50
